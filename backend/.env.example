APP_NAME="Bet9X API"
ENVIRONMENT="development"

# Required
DATABASE_URL="postgresql+psycopg://postgres:postgres@127.0.0.1:5432/ipl2"
JWT_SECRET_KEY="change-me-to-a-long-random-secret"

# Optional
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
CORS_ORIGINS="http://localhost:8080,http://127.0.0.1:8080"

# Razorpay (Payment Links) - deposits redirect to Razorpay
# Create keys in Razorpay Dashboard: Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Webhooks (production). Local-only dev can skip and use verify endpoint.
RAZORPAY_WEBHOOK_SECRET=""

# Optional: public frontend URL used for Payment Link callback_url
PUBLIC_APP_URL="http://localhost:8080"

# CricAPI (live IPL data sync)
CRICAPI_BASE_URL="https://api.cricapi.com"
CRICAPI_API_KEY="9b5dcf2d-907b-4428-8706-f7f6595f3260"
CRICAPI_TIMEOUT_SECONDS="15"
CRICAPI_CURRENT_MATCHES_PATH="/v1/currentMatches"

